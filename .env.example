# =============================================================================
# Wren environment variables (canonical config source).
# Copy to .env and fill in values:  cp .env.example .env
#
# One sectioned root .env, grouped by consumer. This file is the single source
# every doc links to. Never commit a real .env (it is gitignored); this example
# is safe.
# =============================================================================

# --- Shared (both backend apps) ---------------------------------------------

# Runtime environment identifier. Anything other than "development" makes logs
# render as JSON. Consumer: backend (external :8000 + internal :8001).
ENVIRONMENT=development

# Application log level: debug, info, warning, error, critical.
# Consumer: backend.
LOG_LEVEL=info

# Interface the app binds inside its container. Ingress is tunnel-only, so
# binding all interfaces is intentional. Consumer: backend.
HOST=0.0.0.0

# Comma-separated proxy IPs/CIDRs the backend EXTERNAL app trusts for
# X-Forwarded-* headers (uvicorn ProxyHeadersMiddleware). Behind the Cloudflare
# tunnel uvicorn receives plaintext http, so the external app adopts the tunnel's
# X-Forwarded-Proto only from a trusted edge IP. A DISTINCT name from uvicorn's
# native FORWARDED_ALLOW_IPS on purpose (the app layer is the single trust
# source). Leave blank for the host inner loop (`just dev-api`): the middleware
# is not mounted. In the docker stack compose sets this from APP_NET_SUBNET
# (below). The internal app reads it too but never mounts the middleware.
# Consumer: backend external app.
TRUSTED_PROXIES=

# Pinned public URLs (the "Site-URL gotcha"). cloudflared
# reaches the origin as http://backend:8000, so ALL OAuth issuer/metadata/redirect
# URLs are built from these, never from the request host. `PUBLIC_BASE_URL` is the
# AS/API origin (api.usewren.com); `APP_PUBLIC_URL` is the SPA that renders consent
# (usewren.com); `MCP_PUBLIC_URL` is the MCP resource agent tokens are audience-
# bound to (mcp.usewren.com). Dev defaults target localhost. Consumer: backend
# and the MCP server (the RS validates agent tokens against PUBLIC_BASE_URL's
# JWKS, audience-bound to MCP_PUBLIC_URL).
PUBLIC_BASE_URL=http://localhost:8000
APP_PUBLIC_URL=http://localhost:5173
MCP_PUBLIC_URL=http://localhost:9000

# --- Backend container entrypoint (docker/serve.sh) -------------------------
#
# Read only by backend/docker/serve.sh, which launches both backend apps in one
# container image. The host-run `just dev-api`/`dev-api-internal` recipes pass
# --host/--port on the command line instead, so these do not affect the host
# inner loop. Not read by the app processes themselves.

# Ports the two backend apps listen on inside the container (external :8000,
# internal :8001). Consumer: backend/docker/serve.sh.
EXTERNAL_PORT=8000
INTERNAL_PORT=8001

# Set to "true" to launch uvicorn with --reload in the container (the dev overlay
# bind-mounts src/ over the editable install). Any other value disables reload.
# Consumer: backend/docker/serve.sh.
UVICORN_RELOAD=false

# --- Database ---------------------------------------------------------------

# Async SQLAlchemy connection URL (asyncpg driver; the `+asyncpg` suffix is
# required). The dev value targets the Postgres in docker-compose.dev.yml,
# published to localhost by `just dev-infra`. In prod this is the in-network
# form, e.g. postgresql+asyncpg://wren:<pw>@postgres:5432/wren. Consumer: backend
# (engine + pool) and Alembic (migrations).
DATABASE_URL=postgresql+asyncpg://wren:wren@localhost:5432/wren

# --- Internal trust boundary (backend internal :8001) -----------------------

# Shared secret the MCP server must send (X-Internal-Api-Token header) to reach
# the internal app. The internal app is non-tunnel-routed and non-host-published,
# so this token is the PRIMARY boundary on :8001:
# this token ensures a future misconfig that exposes :8001 does not instantly
# leak data. Leave blank and require_internal_user fail-safe denies. Use a strong
# random value in prod. Consumer: backend internal app + MCP client.
INTERNAL_API_TOKEN=dev-internal-token

# Base URL of the backend internal app the MCP server forwards tool calls to. On
# the VPS this is the in-network form http://backend:8001 (app-net; never
# tunnel-routed, token-gated); dev targets a locally-run internal app. The MCP client
# sends X-User-ID + INTERNAL_API_TOKEN on every call. Consumer: MCP server.
BACKEND_INTERNAL_URL=http://localhost:8001

# --- MCP Resource Server (mcp :9000) ----------------------------------------

# Port the MCP Resource Server binds. Dev default 9000 (matches MCP_PUBLIC_URL).
# The container publishes this on the VPS. NOTE: this maps to the bare `PORT`
# env var, so a platform that injects its own PORT would be picked up here.
# Consumer: MCP server (mcp/src/wren_mcp/settings.py).
PORT=9000

# Comma-separated proxy IPs/CIDRs the MCP server trusts for X-Forwarded-* headers
# (uvicorn ProxyHeadersMiddleware). Same tunnel rationale as backend TRUSTED_PROXIES;
# a DISTINCT name from uvicorn's FORWARDED_ALLOW_IPS so the app layer is the single
# trust source. Leave blank for the host inner loop (`just dev-mcp`): the middleware
# is not mounted. In the docker stack compose sets this from APP_NET_SUBNET (below).
# Consumer: MCP server (mcp/src/wren_mcp/settings.py).
MCP_TRUSTED_PROXIES=

# --- Human sessions (backend external :8000) --------------------------------

# HS256 secret signing human session JWTs, kept separate from
# the agent OAuth keypair so the two actors have separate blast radii. Must be
# at least 32 bytes outside development (the app fails fast otherwise); leave
# blank in development and the external app fail-safe denies every session (no
# cookie resolves). Use a strong random value in prod. Consumer: backend external app.
SESSION_JWT_SECRET=dev-session-secret-change-me-min-32-bytes

# Cookie Domain for the session cookie. Prod pins `.usewren.com` so the SPA
# (usewren.com) and API (api.usewren.com) share the session; leave blank in dev
# so the cookie is host-only (localhost). Consumer: backend external app.
COOKIE_DOMAIN=

# --- Agent OAuth 2.1 Authorization Server (backend external :8000) ----------

# Path to the AS signing private-key PEM (RS256), mounted read-only (chmod 600)
# in prod, separate from the human HS256 session secret (separate blast radii).
# The MCP Resource Server verifies agent tokens via the public
# JWKS the AS publishes. Leave blank in development and the app generates an
# ephemeral in-memory keypair on boot; outside development a missing key fails
# fast. Generate one with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out oauth_private.pem
# Consumer: backend external app (OAuth AS).
OAUTH_PRIVATE_KEY_PATH=

# The active signing key id (`kid`) published in the JWKS and set on token
# headers. Rotation publishes a new key under a new kid, signs with it, then
# retires the old kid once existing tokens expire. Consumer: backend external app.
OAUTH_KEY_ID=wren-oauth-dev

# Agent token lifetimes: a short-lived access token plus a long rotating refresh
# token (seconds). Defaults: 15 minutes / 30 days. Consumer: backend external app.
OAUTH_ACCESS_TTL_SECONDS=900
OAUTH_REFRESH_TTL_SECONDS=2592000

# --- CORS (backend external :8000) ------------------------------------------

# The single browser origin allowed to send credentialed SPA XHRs (the consent
# and login flow: /authorize/context, /authorize/decision, /me/clients), with
# Access-Control-Allow-Credentials so the cross-subdomain cookie flow works.
# Prod pins https://usewren.com; leave blank in dev to fall
# back to APP_PUBLIC_URL. Consumer: backend external app.
CORS_ORIGIN=

# --- Infrastructure / Docker Compose ----------------------------------------
#
# Consumed by docker-compose.yml (interpolation), not by the app processes.
#
# NOTE on in-network vs host URLs: the containerized stack reaches services by
# name (postgres, backend, mcp), so docker-compose.yml overrides DATABASE_URL
# and BACKEND_INTERNAL_URL to the in-network form regardless of the host-oriented
# values above (which serve the host-run inner loop, `just dev-api`). The dev
# overlay additionally points PUBLIC_BASE_URL/MCP_PUBLIC_URL in-network so
# `just up-dev` is a self-contained local stack.

# GitHub Container Registry owner for first-party images
# (ghcr.io/<owner>/wren/{backend,mcp,frontend}). Consumer: docker-compose.yml,
# CD image build/push.
GHCR_OWNER=wren-platform

# Tag pulled/built for the first-party images. `latest` for local; CD dual-tags
# `:latest` + `:sha-<sha>` for rollback. Consumer: docker-compose.yml.
WREN_IMAGE_TAG=latest

# Subnet (CIDR) the app-net docker bridge is PINNED to at DEPLOY (the tunnel
# overlay), so cloudflared's container IP lands in a known range; compose passes
# this same CIDR to the backend (TRUSTED_PROXIES) and mcp (MCP_TRUSTED_PROXIES)
# services as the trusted proxy range for X-Forwarded-Proto. Left outside Docker's
# default auto-allocation pool (172.16/12, 192.168/16) so the pinned network never
# overlaps a sibling Docker auto-assigns a /16 to. The base/local/e2e stacks leave
# app-net auto-assigned (no pin) and the trust env is inert there. Override if it
# clashes with a host network. Consumer: docker-compose.yml (+ tunnel overlay).
APP_NET_SUBNET=10.89.0.0/24

# Postgres container bootstrap credentials. Must be consistent with DATABASE_URL.
# In prod set a strong POSTGRES_PASSWORD and the matching DATABASE_URL password.
# Consumer: docker-compose.yml (postgres service + the in-network DATABASE_URL).
POSTGRES_USER=wren
POSTGRES_PASSWORD=wren
POSTGRES_DB=wren

# --- Alerting + signup notifications (Discord) -------------------------------
#
# One Discord Incoming Webhook with TWO consumers in the deploy:
#
#  1. Alertmanager routes the three critical alerts (ServiceDown,
#     HostDiskAlmostFull, HighErrorRate) here with send_resolved. Alertmanager
#     does not read this env var directly: in the deploy it is a GitHub Actions
#     secret that CI feeds to envsubst to render the committed alertmanager.yml
#     into the WREN_ALERTMANAGER_CONFIG env var, delivered as an environment-
#     sourced secret (no rendered file on the box).
#  2. The backend external app (:8000) reads DISCORD_WEBHOOK_URL from its own
#     environment (docker-compose.deploy.yml passes it through) and posts a
#     best-effort, fire-and-forget message on each successful signup. Delivery
#     never blocks or fails registration; when this is blank the notification
#     path is a no-op (the app still boots and registers users normally).
#
# Both consumers share one channel, so routine signup chatter lands alongside
# the P0 operational alerts. Acceptable on a low-signup platform; if the noise or
# an independent kill-switch ever matters, add a dedicated DISCORD_SIGNUP_WEBHOOK_URL
# (see docs/monitoring.md).
#
# Alertmanager v0.27 EXITS on config load unless webhook_url is a valid URL, so a
# blank/unrendered placeholder makes the container fail to start (it is NOT
# boot-safe). It is therefore gated behind the `tunnels` compose profile: local
# `just up`/`up-dev` do not start it (Prometheus + node-exporter still run), so
# leaving this blank locally is fine. In the real deploy CI renders a valid webhook
# AND the deploy health gate polls every service, so a missing render/webhook is
# release-gating (see docs/monitoring.md). To exercise alerting locally, export the
# rendered config and start under the `tunnels` profile, e.g.
# `export WREN_ALERTMANAGER_CONFIG="$(just render-alertmanager)"`.
# Consumers: Alertmanager (via CI render) + backend external app (signup notify).
DISCORD_WEBHOOK_URL=

# --- Cloudflare tunnel (deploy-time) ----------------------------------------
#
# In the deploy these live in the committed .env.prod (non-secret), not here; CI
# envsubst-renders config.yml into the WREN_CLOUDFLARED_INGRESS env var that
# docker-compose.tunnel.yml delivers as an environment-sourced Compose config to
# cloudflared. NOT used locally: the base stack runs without the tunnel. The
# named-tunnel credentials.json is the WREN_CLOUDFLARED_CREDENTIALS GitHub secret;
# cert.pem is a bring-up-only tunnel-management artifact.

# The named tunnel's UUID (from `cloudflared tunnel create` at bring-up).
# Consumer: scripts/deploy.sh (tunnel config render).
CF_TUNNEL_ID=

# Public hostnames routed by the ingress rules. The MCP host publicly
# exposes ONLY the PRM discovery doc + the /mcp transport (path-scoped at
# ingress); /metrics, /healthz and /readyz are never tunnel-routed. The docs
# host serves the static docs site; its /healthz is local-only (not tunnel-
# routed). Dev leaves these blank (no local tunnel). Consumer: scripts/deploy.sh
# (tunnel config render).
CF_APP_HOSTNAME=usewren.com
CF_API_HOSTNAME=api.usewren.com
CF_MCP_HOSTNAME=mcp.usewren.com
CF_DOCS_HOSTNAME=docs.usewren.com
