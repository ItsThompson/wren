          "sections": {
            "additionalProperties": {
              "$ref": "#/components/schemas/Section"
            },
            "type": "object",
            "title": "Sections"
          },
          "section_order": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Section Order"
          },
          "suggested_path": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Suggested Path"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "remap": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Remap"
          }
        },
        "type": "object",
        "required": [
          "id",
          "owner",
          "title",
          "created_at",
          "updated_at"
        ],
        "title": "RoadmapCreated",
        "description": "The ``POST /roadmaps`` body: the full minted roadmap plus a ``remap`` of\nevery de-duped ``proposed_id -> minted_id`` so the author can reconcile the\nreferences it sent (spec section 04). ``remap`` is empty when no proposed ID\nhad to be changed."
      },
      "RoadmapInput": {
        "properties": {
          "proposed_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Proposed Id"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "subject_tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Subject Tags"
          },
          "visibility": {
            "$ref": "#/components/schemas/Visibility",
            "default": "private"
