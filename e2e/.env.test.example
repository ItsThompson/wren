# E2E test config (spec section 11 local-dev: separate e2e/.env.test). Copy to
# e2e/.env.test and override if the stack is published on non-default host ports.
# These match e2e/docker-compose.e2e.yml (frontend :5173 -> :80, backend :8000).
#
# FRONTEND_BASE_URL  the SPA origin Playwright drives in the browser.
# API_BASE_URL       the external app origin the APIRequestContext seeds against.
FRONTEND_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
